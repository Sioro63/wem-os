# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:1234@localhost:5432/wem_os?schema=public"

# ── Better Auth ──────────────────────────────────────────────────────────────
# Secret used to sign sessions. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-32-byte-random-string"
# Base URL of the application (no trailing slash).
BETTER_AUTH_URL="http://localhost:3000"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
