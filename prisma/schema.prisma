// WEM OS — Prisma schema
// ─────────────────────────────────────────────────────────────────────────────
// Normalized schema for Version 1 modules. Enterprise modules (purchase orders,
// shipments, accounting, …) are intentionally NOT modeled yet — see the
// "Future architecture" notes at the bottom of this file and docs/ARCHITECTURE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

/// Access roles. Stored on the user and mapped to permissions in
/// `lib/permissions.ts`. Kept as an enum (not a table) in V1 for cheap,
/// join-free authorization checks; a `Role`/`Permission` table pair is the
/// planned upgrade path when custom roles are needed.
enum UserRole {
  OWNER
  MANAGER
  SALES
  WAREHOUSE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

enum SalesOrderStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum MissingProductStatus {
  OPEN
  SOURCING
  FULFILLED
  CLOSED
}

/// Which price a customer is charged by default.
enum PriceLevel {
  SRP
  DEALER
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (Better Auth core models + WEM role field)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          UserRole @default(SALES)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions               Session[]
  accounts               Account[]
  quotes                 Quote[]
  salesOrders            SalesOrder[]
  missingProductRequests MissingProductRequest[]
  activityLogs           ActivityLog[]

  @@map("user")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Supplier {
  id            String   @id @default(cuid())
  name          String   @unique
  contactPerson String?
  email         String?
  phone         String?
  country       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products Product[]
  // Future: purchaseOrders PurchaseOrder[]
}

model Product {
  id          String        @id @default(cuid())
  sku         String        @unique
  name        String
  description String?
  country     String? // country of origin
  cost        Decimal       @db.Decimal(12, 2)
  srp         Decimal       @db.Decimal(12, 2)
  dealerPrice Decimal       @db.Decimal(12, 2)
  imageUrl    String?
  status      ProductStatus @default(ACTIVE)

  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  brandId    String?
  brand      Brand?    @relation(fields: [brandId], references: [id])
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  inventory       Inventory[]
  quoteItems      QuoteItem[]
  salesOrderItems SalesOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([supplierId])
  @@index([status])
  @@index([name])
}

// ─────────────────────────────────────────────────────────────────────────────
// Inventory
// ─────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory Inventory[]
  // Future: shipments Shipment[], stockTransfers StockTransfer[]
}

/// One row per (product, warehouse). Available stock is derived:
/// available = physicalStock - reservedStock (never stored, never drifts).
model Inventory {
  id            String @id @default(cuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  physicalStock Int    @default(0)
  reservedStock Int    @default(0)
  minimumStock  Int    @default(0)
  reorderPoint  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, warehouseId])
  @@index([warehouseId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Customers & sales documents
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id            String     @id @default(cuid())
  company       String
  contactPerson String
  email         String     @unique
  phone         String
  address       String
  region        String
  priceLevel    PriceLevel @default(SRP)
  notes         String?

  quotes                 Quote[]
  salesOrders            SalesOrder[]
  missingProductRequests MissingProductRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([company])
  @@index([region])
}

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique // e.g. Q-2026-0001
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime?
  notes       String?

  subtotal Decimal @db.Decimal(14, 2)
  discount Decimal @default(0) @db.Decimal(14, 2)
  tax      Decimal @default(0) @db.Decimal(14, 2)
  total    Decimal @db.Decimal(14, 2)

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  items      QuoteItem[]
  salesOrder SalesOrder? // set when an accepted quote is converted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(14, 2)

  @@index([quoteId])
  @@index([productId])
}

model SalesOrder {
  id          String           @id @default(cuid())
  orderNumber String           @unique // e.g. SO-2026-0001
  status      SalesOrderStatus @default(PENDING)
  notes       String?

  subtotal Decimal @db.Decimal(14, 2)
  discount Decimal @default(0) @db.Decimal(14, 2)
  tax      Decimal @default(0) @db.Decimal(14, 2)
  total    Decimal @db.Decimal(14, 2)

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  quoteId     String?  @unique
  quote       Quote?   @relation(fields: [quoteId], references: [id])

  items SalesOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(14, 2)

  @@index([salesOrderId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Missing product requests
// ─────────────────────────────────────────────────────────────────────────────

model MissingProductRequest {
  id          String               @id @default(cuid())
  description String
  quantity    Int
  imageUrl    String?
  status      MissingProductStatus @default(OPEN)
  notes       String?

  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  requestedById String
  requestedBy   User     @relation(fields: [requestedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  action     String // e.g. "product.created", "quote.accepted"
  entityType String // e.g. "Product", "Quote"
  entityId   String?
  summary    String // human-readable line for the dashboard feed
  metadata   Json?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Future architecture (V2+) — intentionally not implemented.
//
// The schema above leaves clean seams for:
//  • PurchaseOrder / PurchaseOrderItem   → hangs off Supplier + Product
//  • Shipment / ShipmentItem             → hangs off SalesOrder + Warehouse
//  • StockMovement (barcode scanning)    → append-only ledger keyed to Inventory
//  • TechnicianJob                       → hangs off Customer + SalesOrder
//  • Payment / Invoice (accounting)      → hangs off SalesOrder + Customer
//  • Role / Permission tables            → replaces the UserRole enum
// See docs/ARCHITECTURE.md for the full plan.
// ─────────────────────────────────────────────────────────────────────────────
